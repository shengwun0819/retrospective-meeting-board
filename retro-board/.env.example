# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Base URL (required for SSR API calls)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ClickUp Integration
# ClickUp is integrated via ClickUp MCP Server and executed by Claude Code — no API token needed here.
# Configure the ClickUp MCP Server in Claude Code settings (~/.claude/settings.json).
# See: https://github.com/tarasglek/clickup-mcp-server or the official ClickUp MCP
